-- Songbook category support.
--
-- An audiobook flagged as `is_songbook = true` is generated by
-- explaining a song's lyrics chapter-by-chapter. The outline pipeline
-- runs the dedicated `outline_songbook` prompt (with lyrics + artist
-- info fetched via the Tinyfish CLI) instead of the standard outline.

DEFINE FIELD IF NOT EXISTS is_songbook ON audiobook TYPE bool DEFAULT false;
