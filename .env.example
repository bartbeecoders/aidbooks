# Copy to .env and fill in. The .env file is gitignored.

# --- Server ---
LISTENAI_HOST=127.0.0.1
LISTENAI_PORT=8787
LISTENAI_LOG=listenai=debug,tower_http=debug,info

# --- Storage ---
LISTENAI_DATABASE_PATH=./storage/db
LISTENAI_STORAGE_PATH=./storage/audio

# --- Auth (Phase 2) ---
# Generate with: openssl rand -hex 32
LISTENAI_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
LISTENAI_PASSWORD_PEPPER=change-me-too
LISTENAI_ACCESS_TOKEN_TTL_SECS=900
LISTENAI_REFRESH_TOKEN_TTL_SECS=2592000

# --- Dev-only seed ---
# When true, a demo admin user (demo@listenai.local / "demo") is upserted
# into the DB on every startup. NEVER enable this in production.
LISTENAI_DEV_SEED=true

# --- LLM (added in Phase 3) ---
OPENROUTER_API_KEY=

# --- TTS (added in Phase 4) ---
XAI_API_KEY=

# --- Email (added in Phase 2) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Billing (added in Phase 9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
