# Copy to .env and fill in. The .env file is gitignored.

# --- Server ---
LISTENAI_HOST=127.0.0.1
LISTENAI_PORT=8787
LISTENAI_LOG=listenai=debug,tower_http=debug,info

# --- Storage ---
LISTENAI_DATABASE_PATH=./storage/db
LISTENAI_STORAGE_PATH=./storage/audio

# --- Auth (Phase 2) ---
# Generate with: openssl rand -hex 32
LISTENAI_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
LISTENAI_PASSWORD_PEPPER=change-me-too
LISTENAI_ACCESS_TOKEN_TTL_SECS=900
LISTENAI_REFRESH_TOKEN_TTL_SECS=2592000

# --- Dev-only seed ---
# When true, a demo admin user (demo@listenai.local / "demo") is upserted
# into the DB on every startup. NEVER enable this in production.
LISTENAI_DEV_SEED=true

# --- LLM (Phase 3) ---
# When empty, the server runs in MOCK mode — it fabricates outlines and
# chapters so local dev works without a real API key. Never rely on mock
# mode for any real user traffic.
LISTENAI_OPENROUTER_API_KEY=
LISTENAI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LISTENAI_OPENROUTER_REQUEST_TIMEOUT_SECS=120
LISTENAI_OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4.5

# --- TTS (Phase 4) ---
# When empty, the server runs TTS in MOCK mode — produces audible silence-
# equivalent PCM scaled to the text length so the full pipeline can be
# exercised without x.ai. Never rely on mock mode for real user traffic.
LISTENAI_XAI_API_KEY=
LISTENAI_XAI_TTS_URL=https://api.x.ai/v1/tts
LISTENAI_XAI_TTS_LANGUAGE=en
LISTENAI_XAI_DEFAULT_VOICE=eve
LISTENAI_XAI_SAMPLE_RATE_HZ=24000
LISTENAI_XAI_REQUEST_TIMEOUT_SECS=180

# --- Email (added in Phase 2) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Billing (added in Phase 9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# --- YouTube publishing (Phase 8) ---
# OAuth 2.0 web-app credentials for the Google Cloud project that owns
# the youtube.upload scope. Leave the id/secret blank to disable publishing.
LISTENAI_YOUTUBE_CLIENT_ID=
LISTENAI_YOUTUBE_CLIENT_SECRET=
LISTENAI_YOUTUBE_REDIRECT_URI=http://localhost:8787/integrations/youtube/oauth/callback
# Where the OAuth callback bounces the user back to after success.
LISTENAI_YOUTUBE_POST_CONNECT_REDIRECT=http://localhost:5173/app/settings
# Path to the ffmpeg binary used to mux cover.png + chapter WAVs into MP4.
LISTENAI_FFMPEG_BIN=ffmpeg