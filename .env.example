# Copy to .env and fill in. The .env file is gitignored.

# --- Server ---
LISTENAI_HOST=127.0.0.1
LISTENAI_PORT=8787
LISTENAI_LOG=listenai=debug,tower_http=debug,info
# Wall-clock cap on every HTTP request. Must be ≥ the longest legitimate
# upstream timeout (xAI = 180s) or synchronous LLM/translate/classify
# handlers get cut off with a 408 mid-flight.
LISTENAI_REQUEST_TIMEOUT_SECS=180

# --- Storage ---
LISTENAI_DATABASE_PATH=./storage/db
LISTENAI_STORAGE_PATH=./storage/audio

# --- Auth (Phase 2) ---
# Generate with: openssl rand -hex 32
LISTENAI_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
LISTENAI_PASSWORD_PEPPER=change-me-too
LISTENAI_ACCESS_TOKEN_TTL_SECS=900
LISTENAI_REFRESH_TOKEN_TTL_SECS=2592000

# --- Dev-only seed ---
# When true, a demo admin user (demo@listenai.local / "demo") is upserted
# into the DB on every startup. NEVER enable this in production.
LISTENAI_DEV_SEED=true

# --- LLM (Phase 3) ---
# When empty, the server runs in MOCK mode — it fabricates outlines and
# chapters so local dev works without a real API key. Never rely on mock
# mode for any real user traffic.
LISTENAI_OPENROUTER_API_KEY=
LISTENAI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LISTENAI_OPENROUTER_REQUEST_TIMEOUT_SECS=120
LISTENAI_OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4.5

# --- TTS (Phase 4) ---
# When empty, the server runs TTS in MOCK mode — produces audible silence-
# equivalent PCM scaled to the text length so the full pipeline can be
# exercised without x.ai. Never rely on mock mode for real user traffic.
LISTENAI_XAI_API_KEY=
LISTENAI_XAI_TTS_URL=https://api.x.ai/v1/tts
LISTENAI_XAI_TTS_LANGUAGE=en
LISTENAI_XAI_DEFAULT_VOICE=eve
LISTENAI_XAI_SAMPLE_RATE_HZ=24000
LISTENAI_XAI_REQUEST_TIMEOUT_SECS=180

# --- Email (added in Phase 2) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Billing (added in Phase 9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# --- YouTube publishing (Phase 8) ---
# OAuth 2.0 web-app credentials for the Google Cloud project that owns
# the youtube.upload scope. Leave the id/secret blank to disable publishing.
LISTENAI_YOUTUBE_CLIENT_ID=
LISTENAI_YOUTUBE_CLIENT_SECRET=
LISTENAI_YOUTUBE_REDIRECT_URI=http://localhost:8787/integrations/youtube/oauth/callback
# Where the OAuth callback bounces the user back to after success.
LISTENAI_YOUTUBE_POST_CONNECT_REDIRECT=http://localhost:5173/app/settings
# Path to the ffmpeg binary used to mux cover.png + chapter WAVs into MP4.
LISTENAI_FFMPEG_BIN=ffmpeg

# --- Animation (feature/animation, Phases A–F) ---
# Path to the long-lived renderer sidecar (Phase F.1a). Build it with
# `cd backend/render && npm install && npm run build`; the entry point
# is `dist/server.js`. The Rust pool spawns one child per worker slot
# and pipes SceneSpecs over stdin (NDJSON). Empty = animate jobs refuse
# to run, so the publisher's `animate=true` mode is also disabled.
# A legacy `dist/cli.js` value is auto-mapped to `dist/server.js` for
# back-compat — update the env to silence the warning.
LISTENAI_ANIMATE_RENDERER_CMD=
# Path to the Node binary. `node` works on most systems; pin to e.g.
# /usr/bin/node when running under a system service that doesn't see PATH.
LISTENAI_ANIMATE_NODE_BIN=node
# Render frame rate (Phase F.1b). Default 24 — a ~20% CPU cut over 30
# with no visible diff for our karaoke + Ken Burns layout. Bump to 30
# only if you really need it; chapters cache by spec hash, so flipping
# this invalidates the cache on next render.
LISTENAI_ANIMATE_FPS=24
# Number of parallel `AnimateChapter` workers (Phase F.1d). 0 = auto
# (`min(cpu_count, 4)`). Each worker holds ~400 MB Chromium RSS via
# its long-lived sidecar; budget memory accordingly when overriding.
LISTENAI_ANIMATE_CONCURRENCY=0
# Phase F.1c — single-shot ffmpeg per chapter (no Chromium / Revideo).
# ~5–10× faster on paragraph-dominant chapters. Visual differences:
# no animated title underline, no per-paragraph tile overlays, no
# per-word karaoke (text appears on cue and holds), hard cuts between
# scenes. Off by default until shaken out on real content. Flipping
# this invalidates the F.1e spec-hash cache.
LISTENAI_ANIMATE_FAST_PATH=false
# Phase F.1f.1 — hardware encoder for the fast path. `auto` (default)
# probes ffmpeg + the host's GPU device files and picks NVENC > VAAPI
# > QSV > libx264. Force a specific encoder with `nvenc`, `vaapi`,
# `qsv`. Force CPU with `none` / `software` / `cpu`. Empirical wins
# on real chapters: NVENC ~6–8×, VAAPI ~4–6×, QSV ~3–5× over libx264
# at the same CRF. Doesn't invalidate the F.1e cache.
LISTENAI_ANIMATE_HWENC=auto
# DRI render node for VAAPI / QSV. Default is fine on VAAPI-only
# hosts. On hybrid systems (e.g. discrete NVIDIA + integrated Intel)
# the integrated GPU is often `renderD129`; override here so
# auto-detect picks it instead of trying VAAPI on the dGPU.
LISTENAI_ANIMATE_VAAPI_DEVICE=/dev/dri/renderD128
# Phase G.6 — Manim sidecar (STEM diagram render path). Set to
# the venv's `listenai-manim-server` script, e.g.
# `<repo>/backend/manim/.venv/bin/listenai-manim-server`. Empty
# leaves the toolchain wired but falls back to prose rendering for
# every diagram scene with a warn log — useful for quick visual
# QA without spinning up Manim. Only takes effect when the book
# is STEM (`is_stem=true` after override or detection) AND
# LISTENAI_ANIMATE_FAST_PATH=true.
LISTENAI_ANIMATE_MANIM_CMD=
# Python interpreter to launch the Manim sidecar with. The venv's
# interpreter is the right value when the book host has conda
# activated by default — it bypasses conda entirely and uses the
# Manim install we set up via scripts/manim-install.sh.
LISTENAI_ANIMATE_MANIM_PYTHON_BIN=python
# LD_PRELOAD applied to the Manim sidecar. On Arch the manimpango
# wheel bundles an older libfontconfig that crashes against the
# system pango; pre-loading /usr/lib/libfontconfig.so.1 fixes it.
# Same trick the `just manim-smoke` recipe uses; empty if the
# preload isn't needed on your host.
LISTENAI_ANIMATE_MANIM_LD_PRELOAD=/usr/lib/libfontconfig.so.1
# Mock mode: skip the Node sidecar and write a black 1080p MP4 of the
# right duration via ffmpeg. Mirrors `MockTts` — useful for proving the
# wiring end-to-end without Chromium / Revideo. Never enable in prod.
LISTENAI_ANIMATE_MOCK=false